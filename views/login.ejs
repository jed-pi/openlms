<%- include('partials/header', { title: 'Sign in' }) %>
<div class="card narrow">
  <h1>Sign in to your training</h1>
  <p class="muted">Enter your details and we'll email you a secure sign-in link — no password needed.</p>
  <% if (error) { %><p class="error"><%= error %></p><% } %>
  <form method="post" action="/login" class="stack">
    <input type="hidden" name="next" value="<%= next %>">
    <label>Full name
      <input name="full_name" required autocomplete="name" value="<%= values.full_name || '' %>">
    </label>
    <label>Email address
      <input type="email" name="email" required autocomplete="email" value="<%= values.email || '' %>">
    </label>
    <button class="btn primary" type="submit">Email me a sign-in link</button>
  </form>
</div>
<%- include('partials/footer') %>
