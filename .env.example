# ---------------------------------------------------------------------------
# Woodhouse Park Training — environment configuration
# Copy this file to ".env" and fill in the values. Never commit .env.
# ---------------------------------------------------------------------------

# Public base URL of the site (used in magic-link and certificate-verify links).
# Local dev: http://localhost:3000   Production: https://training.your-domain.org
SITE_URL=http://localhost:3000
PORT=3000

# Secret used to sign the session cookie. Generate a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- Database -------------------------------------------------------------
# Leave DATABASE_URL EMPTY for local development: the app uses an embedded
# Postgres (PGlite) stored under ./data/pgdata — no Docker or install needed.
#
# In production, set this to your Supabase Postgres connection string
# (Supabase dashboard -> Project Settings -> Database -> Connection string ->
#  "URI", use the pooler/transaction string). Example:
#   DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Email (SMTP) ---------------------------------------------------------
# The charity's existing SMTP credentials. Used for magic-link sign-in emails
# and for sending certificates. Leave SMTP_HOST empty in local dev to print
# emails to the console instead of sending them.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Woodhouse Park Training <training@your-domain.org>"

# --- Admins ---------------------------------------------------------------
# Comma-separated emails that automatically become admins when they sign in.
ADMIN_EMAILS=

# --- Branding -------------------------------------------------------------
ORG_NAME=Woodhouse Park Activity Centre
