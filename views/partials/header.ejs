<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title + ' · ' : '' %><%= orgName %></title>
  <link rel="stylesheet" href="/public/css/styles.css">
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/dashboard"><img src="/public/brand/logo.png" alt="<%= orgName %>"></a>
    <nav>
      <% if (locals.learner) { %>
        <span class="who"><%= learner.full_name %></span>
        <% if (learner.is_admin) { %><a href="/admin">Admin</a><% } %>
        <form method="post" action="/logout" class="inline"><button class="linkbtn">Sign out</button></form>
      <% } %>
    </nav>
  </header>
  <main class="container">
